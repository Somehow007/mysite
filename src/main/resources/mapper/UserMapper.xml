<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.somehow.mysite.dao.mapper.UserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="io.github.somehow.mysite.dao.entity.UserDO">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="sex" property="sex"/>
        <result column="email" property="email"/>
        <result column="phone_number" property="phoneNumber"/>
        <result column="following_count" property="followingCount"/>
        <result column="follower_count" property="followerCount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="del_flag" property="delFlag"/>
    </resultMap>

    <!-- 根据用户名模糊搜索用户 -->
    <select id="selectByUsernameLike" parameterType="string" resultMap="BaseResultMap">
        SELECT
            id, username, real_name, sex, email, phone_number,
            following_count, follower_count, create_time, update_time, del_flag
        FROM t_user
        WHERE del_flag = 0
          AND username LIKE CONCAT('%', #{username}, '%')
    </select>

    <select id="pageFollowersResult" resultType="io.github.somehow.mysite.dto.resp.user.UserPageQueryFollowRespDTO">
        SELECT
            u.id AS id,
            u.username AS username,
            u.sex AS sex,
            u.following_count AS followingCount,
            u.follower_count AS followerCount
        FROM
            t_user u
        INNER JOIN t_user_follow uf ON u.id = uf.follower_id AND uf.del_flag = 0
        WHERE u.del_flag = 0
        <if test="id != null">
            AND uf.followee_id = #{id}
        </if>
    </select>

    <select id="pageFollowingsResult" resultType="io.github.somehow.mysite.dto.resp.user.UserPageQueryFollowRespDTO">
        SELECT
        u.id AS id,
        u.username AS username,
        u.sex AS sex,
        u.following_count AS followingCount,
        u.follower_count AS followerCount
        FROM
        t_user u
        INNER JOIN t_user_follow uf ON u.id = uf.followee_id AND uf.del_flag = 0
        WHERE u.del_flag = 0
        <if test="id != null">
            AND uf.follower_id = #{id}
        </if>
    </select>
</mapper>