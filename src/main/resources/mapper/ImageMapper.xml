<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.somehow.mysite.dao.mapper.ImageMapper">

    <select id="pageQueryImages"
            parameterType="io.github.somehow.mysite.dto.req.image.ImagePageQueryReqDTO"
            resultType="io.github.somehow.mysite.dto.resp.ImagePageQueryRespDTO">
        SELECT
            id,
            original_name,
            url,
            file_size,
            content_type,
            width,
            height,
            source_type,
            source_url,
            uploader_id,
            create_time
        FROM t_image
        WHERE del_flag = 0
        <if test="keyword != null and keyword != ''">
            AND original_name LIKE CONCAT('%', #{keyword}, '%')
        </if>
        <if test="sourceType != null">
            AND source_type = #{sourceType}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
